@model IEnumerable<ATLAS.Models.Vulnerability>
@{
    ViewData["Title"] = "Vulnerabilities";
}

@* ── Page header ─────────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="mb-0">Vulnerability Library</h2>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#syncPanel"
                aria-expanded="false"
                aria-controls="syncPanel">
            &#8635; Sync from NVD
        </button>
        <a asp-action="Create" class="btn btn-danger">+ Add Manually</a>
    </div>
</div>

@* ── NVD Sync panel ───────────────────────────────────────────────────────── *@
<div class="collapse mb-3" id="syncPanel">
    <div class="card border-primary shadow-sm">
        <div class="card-header bg-primary text-white fw-semibold">
            Sync CVEs from NIST National Vulnerability Database
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">
                Pulls <strong>all matching CVE records</strong> from the
                <a href="https://nvd.nist.gov/developers/vulnerabilities" target="_blank" rel="noopener">
                    NVD API 2.0
                </a>
                and upserts them into your library — new CVEs are added, existing ones are refreshed.
                Leave both filters blank to sync the entire NVD database (~250 k CVEs).
                @if (!(bool)ViewData["NvdKeyConfigured"]!)
                {
                    <span>
                        Without an API key requests are rate-limited (~5 per 30 s); a full unfiltered sync will run
                        in the background for several hours. Add a free key in
                        <code>appsettings.json</code> → <code>"NvdApiKey"</code> to sync the full database in ~15 minutes.
                    </span>
                }
            </p>

            <form id="syncForm">
                @Html.AntiForgeryToken()
                <div class="row g-3 align-items-end">

                    <div class="col-md-5">
                        <label class="form-label fw-semibold">
                            Keyword <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <input type="text" id="syncKeyword" name="keyword" class="form-control"
                               placeholder="e.g. apache, log4j, windows" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            Severity filter <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <select id="syncSeverity" name="severity" class="form-select">
                            <option value="">— All severities —</option>
                            <option value="CRITICAL">Critical</option>
                            <option value="HIGH">High</option>
                            <option value="MEDIUM">Medium</option>
                            <option value="LOW">Low</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button type="button" id="syncBtn" class="btn btn-primary w-100"
                                onclick="startSync()">
                            &#8635; Start Sync
                        </button>
                    </div>

                </div>
            </form>

            @* ── Live progress panel (hidden until sync starts) ────────────── *@
            <div id="syncProgress" class="mt-4 d-none">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span id="syncPhaseLabel" class="fw-semibold text-primary small"></span>
                    <span id="syncElapsed" class="text-muted small"></span>
                </div>

                <div class="progress mb-2" style="height: 18px;">
                    <div id="syncProgressBar"
                         class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="width: 0%"
                         aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                        <span id="syncProgressPct"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <small id="syncCountLabel" class="text-muted"></small>
                    <small id="syncSavedLabel" class="text-muted"></small>
                </div>

                @* Success / error banners shown after completion *@
                <div id="syncSuccessBanner" class="alert alert-success alert-dismissible fade mt-3 d-none" role="alert">
                    <span id="syncSuccessText"></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <div id="syncErrorBanner" class="alert alert-danger alert-dismissible fade mt-3 d-none" role="alert">
                    <span id="syncErrorText"></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>

        </div>
    </div>
</div>

@* ── Vulnerability table ──────────────────────────────────────────────────── *@
<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>CVE ID</th>
            <th>Title</th>
            <th>Severity</th>
            <th>CVSS</th>
            <th>Affected Software</th>
            <th>Affected Assets</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var v in Model)
        {
            <tr>
                <td>
                    @if (v.CveId != null)
                    {
                        <a href="https://nvd.nist.gov/vuln/detail/@v.CveId"
                           target="_blank" rel="noopener"
                           class="font-monospace small text-decoration-none">
                            @v.CveId
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td><a asp-action="Details" asp-route-id="@v.Id">@v.Title</a></td>
                <td><span class="severity-@v.Severity.ToString().ToLower()">@v.Severity</span></td>
                <td>@(v.CvssScore?.ToString("F1") ?? "—")</td>
                <td><small>@v.AffectedSoftware</small></td>
                <td>@v.AssetVulnerabilities.Count</td>
                <td>
                    <a asp-action="Edit"   asp-route-id="@v.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@v.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">
                    No vulnerabilities yet. Use <strong>Sync from NVD</strong> to import CVEs, or
                    <a asp-action="Create">add one manually</a>.
                </td>
            </tr>
        }
    </tbody>
</table>

<p class="text-muted small">@Model.Count() vulnerabilities in library.</p>

@section Scripts {
<script>
    let pollTimer = null;

    async function startSync() {
        const btn      = document.getElementById('syncBtn');
        const keyword  = document.getElementById('syncKeyword').value;
        const severity = document.getElementById('syncSeverity').value;
        const token    = document.querySelector('#syncForm input[name="__RequestVerificationToken"]').value;

        // Reset UI
        hideBanners();
        btn.disabled = true;
        btn.textContent = 'Syncing\u2026';

        const params = new URLSearchParams({ keyword, severity, __RequestVerificationToken: token });

        try {
            const resp = await fetch('@Url.Action("SyncFromNvd", "Vulnerabilities")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: params.toString()
            });
            const data = await resp.json();

            if (!data.started) {
                showError(data.message ?? 'A sync is already running.');
                btn.disabled = false;
                btn.innerHTML = '&#8635; Start Sync';
                return;
            }
        } catch (e) {
            showError('Failed to start sync: ' + e.message);
            btn.disabled = false;
            btn.innerHTML = '&#8635; Start Sync';
            return;
        }

        // Show the progress panel and start polling
        document.getElementById('syncProgress').classList.remove('d-none');
        pollTimer = setInterval(pollStatus, 2000);
        pollStatus(); // immediate first check
    }

    async function pollStatus() {
        try {
            const resp = await fetch('@Url.Action("SyncStatus", "Vulnerabilities")');
            const s    = await resp.json();
            updateProgress(s);
        } catch (_) {
            // Network hiccup — keep polling
        }
    }

    function updateProgress(s) {
        // Phase label
        const phaseMap = {
            'Idle':     'Idle',
            'Fetching': '⬇ Fetching CVEs from NVD\u2026',
            'Saving':   '💾 Saving to database\u2026',
            'Done':     '✔ Sync complete',
            'Failed':   '✘ Sync failed'
        };
        document.getElementById('syncPhaseLabel').textContent =
            phaseMap[s.phase] ?? s.phase;

        // Elapsed time
        document.getElementById('syncElapsed').textContent =
            s.elapsedSeconds > 0 ? formatElapsed(s.elapsedSeconds) : '';

        // Progress bar
        const bar = document.getElementById('syncProgressBar');
        const pct = document.getElementById('syncProgressPct');

        if (s.phase === 'Fetching' && s.totalResults > 0) {
            const p = Math.min(100, Math.round((s.totalFetched / s.totalResults) * 100));
            bar.style.width = p + '%';
            bar.setAttribute('aria-valuenow', p);
            pct.textContent = p + '%';
        } else if (s.phase === 'Saving') {
            bar.style.width = '100%';
            bar.setAttribute('aria-valuenow', 100);
            pct.textContent = '100%';
        } else if (s.isDone) {
            bar.classList.remove('progress-bar-animated', 'progress-bar-striped');
            bar.style.width = '100%';
            bar.setAttribute('aria-valuenow', 100);
            pct.textContent = '100%';
        }

        // Fetch counter (left side)
        const countEl = document.getElementById('syncCountLabel');
        if (s.totalResults > 0) {
            countEl.textContent =
                s.totalFetched.toLocaleString() + ' / ' + s.totalResults.toLocaleString() + ' CVEs fetched';
        } else if (s.totalFetched > 0) {
            countEl.textContent = s.totalFetched.toLocaleString() + ' CVEs fetched';
        } else {
            countEl.textContent = '';
        }

        // Saved counter (right side) — updates live after each committed page
        const savedEl = document.getElementById('syncSavedLabel');
        if (s.added > 0 || s.updated > 0) {
            savedEl.textContent =
                s.added.toLocaleString() + ' added · ' + s.updated.toLocaleString() + ' updated';
        } else {
            savedEl.textContent = '';
        }

        // Finished?
        if (s.isDone) {
            clearInterval(pollTimer);
            pollTimer = null;

            const btn = document.getElementById('syncBtn');
            btn.disabled = false;
            btn.innerHTML = '&#8635; Start Sync';

            bar.classList.remove('progress-bar-animated', 'progress-bar-striped');

            if (s.phase === 'Done') {
                bar.classList.remove('bg-danger');
                showSuccess(
                    '✔ Sync complete — ' +
                    s.added.toLocaleString() + ' CVEs added, ' +
                    s.updated.toLocaleString() + ' updated in ' +
                    formatElapsed(s.elapsedSeconds) + '.'
                );
                // Reload the table after a short pause so the new data appears
                setTimeout(() => location.reload(), 2500);
            } else {
                bar.classList.add('bg-danger');
                showError('Sync failed: ' + (s.error ?? 'Unknown error'));
            }
        }
    }

    function formatElapsed(sec) {
        if (sec < 60) return sec + 's';
        const m = Math.floor(sec / 60), s = sec % 60;
        return m + 'm ' + s + 's';
    }

    function showSuccess(msg) {
        const el = document.getElementById('syncSuccessBanner');
        document.getElementById('syncSuccessText').textContent = msg;
        el.classList.remove('d-none');
        el.classList.add('show');
    }

    function showError(msg) {
        document.getElementById('syncProgress').classList.remove('d-none');
        const el = document.getElementById('syncErrorBanner');
        document.getElementById('syncErrorText').textContent = msg;
        el.classList.remove('d-none');
        el.classList.add('show');
    }

    function hideBanners() {
        ['syncSuccessBanner', 'syncErrorBanner'].forEach(id => {
            const el = document.getElementById(id);
            el.classList.add('d-none');
            el.classList.remove('show');
        });
    }
</script>
}
