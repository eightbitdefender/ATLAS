@model CMDB.Models.AssetVulnerability
@{
    ViewData["Title"] = "Assign Vulnerability";
}

<h2 class="mb-4">Assign Vulnerability to Asset</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="AssetId" class="form-label">Asset</label>
                <select asp-for="AssetId" asp-items="@ViewBag.Assets" class="form-select">
                    <option value="">— Select Asset —</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="VulnerabilityId" class="form-label">Vulnerability</label>
                <select asp-for="VulnerabilityId" asp-items="@ViewBag.Vulnerabilities" class="form-select">
                    <option value="">— Select Vulnerability —</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Remediation Status</label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<CMDB.Models.RemediationStatus>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-danger">Assign</button>
            <a asp-controller="Assets" asp-action="Index" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
