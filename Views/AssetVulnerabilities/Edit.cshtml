@model CMDB.Models.AssetVulnerability
@{
    ViewData["Title"] = "Edit Finding";
}

<h2 class="mb-4">Edit Finding</h2>
<p class="text-muted">@Model.Asset?.Name — @Model.Vulnerability?.Title</p>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="AssetId" />
            <input type="hidden" asp-for="VulnerabilityId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Remediation Status</label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<CMDB.Models.RemediationStatus>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="RemediatedAt" class="form-label">Remediated Date (if applicable)</label>
                <input asp-for="RemediatedAt" class="form-control" type="date" />
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-controller="Assets" asp-action="Details" asp-route-id="@Model.AssetId" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
