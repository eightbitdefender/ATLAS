@model ATLAS.Models.AssetFormViewModel
@{
    ViewData["Title"] = "Add Asset";
}

<h2 class="mb-4">Add Asset</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Category" class="form-label fw-semibold fs-5"></label>
                <select asp-for="Category"
                        asp-items="Html.GetEnumSelectList<ATLAS.Models.AssetCategory>()"
                        class="form-select form-select-lg" id="Category"></select>
                <div class="form-text">Choose the asset category — related fields will appear below.</div>
            </div>

            <div class="card mb-4">
                <div class="card-header"><strong>Common Information</strong></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Purpose, role, or any relevant context."></textarea>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<ATLAS.Models.AssetStatus>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Owner" class="form-label"></label>
                            <input asp-for="Owner" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="BusinessStakeholder" class="form-label"></label>
                            <input asp-for="BusinessStakeholder" class="form-control" placeholder="Business owner or sponsor" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Department" class="form-label"></label>
                            <input asp-for="Department" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Location" class="form-label"></label>
                            <input asp-for="Location" class="form-control" />
                        </div>
                        <div class="col mb-3"></div>
                    </div>
                    <div class="mb-0">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <!-- Computer -->
            <div id="section-Computer" class="asset-type-section card mb-4 d-none">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Computer Details</strong>
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#psQueryModal">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-terminal me-1" viewBox="0 0 16 16">
                            <path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9M3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708z"/>
                            <path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/>
                        </svg>
                        Query PowerShell
                    </button>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="ComputerType" class="form-label"></label>
                            <select asp-for="ComputerType" asp-items="Html.GetEnumSelectList<ATLAS.Models.ComputerType>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="IpAddress" class="form-label"></label>
                            <input asp-for="IpAddress" class="form-control" placeholder="192.168.1.1" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="OperatingSystem" class="form-label"></label>
                            <input asp-for="OperatingSystem" class="form-control" placeholder="Windows 11, Ubuntu 24.04..." />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="CpuModel" class="form-label"></label>
                            <input asp-for="CpuModel" class="form-control" placeholder="Intel Core i7-13700K" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="RamGb" class="form-label"></label>
                            <input asp-for="RamGb" class="form-control" type="number" min="1" placeholder="16" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="SerialNumber" class="form-label"></label>
                            <input asp-for="SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-check">
                        <input asp-for="DomainJoined" class="form-check-input" type="checkbox" />
                        <label asp-for="DomainJoined" class="form-check-label"></label>
                    </div>
                    <div id="domainNameRow" class="mt-2 d-none">
                        <label asp-for="DomainName" class="form-label"></label>
                        <input asp-for="DomainName" class="form-control" placeholder="corp.example.com" />
                    </div>
                </div>
            </div>

            <!-- Network Device -->
            <div id="section-NetworkDevice" class="asset-type-section card mb-4 d-none">
                <div class="card-header"><strong>Network Device Details</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="NetworkDeviceType" class="form-label"></label>
                            <select asp-for="NetworkDeviceType" asp-items="Html.GetEnumSelectList<ATLAS.Models.NetworkDeviceType>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="IpAddress" class="form-label"></label>
                            <input asp-for="IpAddress" class="form-control" placeholder="192.168.1.1" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="MacAddress" class="form-label"></label>
                            <input asp-for="MacAddress" class="form-control" placeholder="AA:BB:CC:DD:EE:FF" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Firmware" class="form-label"></label>
                            <input asp-for="Firmware" class="form-control" placeholder="15.3.1" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="PortCount" class="form-label"></label>
                            <input asp-for="PortCount" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col mb-3 d-flex align-items-end pb-2">
                            <div class="form-check">
                                <input asp-for="Managed" class="form-check-input" type="checkbox" />
                                <label asp-for="Managed" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Printer -->
            <div id="section-Printer" class="asset-type-section card mb-4 d-none">
                <div class="card-header"><strong>Printer Details</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="PrinterType" class="form-label"></label>
                            <select asp-for="PrinterType" asp-items="Html.GetEnumSelectList<ATLAS.Models.PrinterType>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="IpAddress" class="form-label"></label>
                            <input asp-for="IpAddress" class="form-control" placeholder="192.168.1.50" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PrinterModel" class="form-label"></label>
                        <input asp-for="PrinterModel" class="form-control" placeholder="HP LaserJet Pro M404n" />
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="form-check">
                                <input asp-for="ColorCapable" class="form-check-input" type="checkbox" />
                                <label asp-for="ColorCapable" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-check">
                                <input asp-for="NetworkConnected" class="form-check-input" type="checkbox" />
                                <label asp-for="NetworkConnected" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Software Application -->
            <div id="section-SoftwareApplication" class="asset-type-section card mb-4 d-none">
                <div class="card-header"><strong>Application Details</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="ApplicationType" class="form-label"></label>
                            <select asp-for="ApplicationType" asp-items="Html.GetEnumSelectList<ATLAS.Models.ApplicationType>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="Vendor" class="form-label"></label>
                            <input asp-for="Vendor" class="form-control" placeholder="Microsoft, Atlassian..." />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Version" class="form-label"></label>
                            <input asp-for="Version" class="form-control" placeholder="2.4.1" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="LicenseType" class="form-label"></label>
                            <input asp-for="LicenseType" class="form-control" placeholder="Enterprise, SaaS, Open Source..." />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label asp-for="Url" class="form-label"></label>
                        <input asp-for="Url" class="form-control" placeholder="https://app.example.com" />
                    </div>
                </div>
            </div>

            <!-- Mobile Device -->
            <div id="section-MobileDevice" class="asset-type-section card mb-4 d-none">
                <div class="card-header"><strong>Mobile Device Details</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="MobileDeviceType" class="form-label"></label>
                            <select asp-for="MobileDeviceType" asp-items="Html.GetEnumSelectList<ATLAS.Models.MobileDeviceType>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="OperatingSystem" class="form-label"></label>
                            <input asp-for="OperatingSystem" class="form-control" placeholder="iOS 17, Android 14..." />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Imei" class="form-label"></label>
                            <input asp-for="Imei" class="form-control" />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+1 555-0100" />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label asp-for="Carrier" class="form-label"></label>
                        <input asp-for="Carrier" class="form-control" placeholder="Verizon, AT&amp;T..." />
                    </div>
                </div>
            </div>

            <!-- Cloud Resource -->
            <div id="section-CloudResource" class="asset-type-section card mb-4 d-none">
                <div class="card-header"><strong>Cloud Resource Details</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="CloudProvider" class="form-label"></label>
                            <select asp-for="CloudProvider" asp-items="Html.GetEnumSelectList<ATLAS.Models.CloudProvider>()" class="form-select"></select>
                        </div>
                        <div class="col mb-3">
                            <label asp-for="ResourceType" class="form-label"></label>
                            <input asp-for="ResourceType" class="form-control" placeholder="EC2, S3, App Service..." />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label asp-for="Region" class="form-label"></label>
                            <input asp-for="Region" class="form-control" placeholder="us-east-1, eastus..." />
                        </div>
                        <div class="col mb-3">
                            <label asp-for="AccountId" class="form-label"></label>
                            <input asp-for="AccountId" class="form-control" placeholder="123456789012" />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label asp-for="ResourceId" class="form-label"></label>
                        <input asp-for="ResourceId" class="form-control" placeholder="arn:aws:ec2:us-east-1:123456789012:instance/i-0abc123" />
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save Asset</button>
            <a asp-action="Index" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

<!-- PowerShell Query Modal (form-fill mode) -->
<div class="modal fade" id="psQueryModal" tabindex="-1" aria-labelledby="psQueryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="psQueryModalLabel">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-terminal me-2" viewBox="0 0 16 16">
                        <path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9M3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708z"/>
                        <path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/>
                    </svg>
                    Query Computer with PowerShell
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-2">
                    <strong>Step 1</strong> — Copy this script and run it in PowerShell on the target computer:
                </p>
                <div class="position-relative mb-3">
                    <textarea id="psScript" class="form-control font-monospace" rows="11" readonly style="font-size:0.82rem; background:#1e1e1e; color:#d4d4d4; resize:none;">$info = [ordered]&#64;{
    Hostname        = $env:COMPUTERNAME
    IpAddress       = (Get-NetIPAddress -AddressFamily IPv4 |
                           Where-Object { $_.IPAddress -notlike '127.*' -and
                                          $_.IPAddress -notlike '169.254.*' } |
                           Sort-Object PrefixLength -Descending |
                           Select-Object -First 1).IPAddress
    OperatingSystem = (Get-CimInstance Win32_OperatingSystem).Caption
    RamGb           = [int][Math]::Ceiling(
                           (Get-CimInstance Win32_PhysicalMemoryArray |
                            Measure-Object -Property MaxCapacity -Sum).Sum / 1MB)
    CpuModel        = ((Get-CimInstance Win32_Processor)[0].Name).Trim()
    SerialNumber    = ((Get-CimInstance Win32_BIOS).SerialNumber).Trim()
    DomainJoined    = (Get-CimInstance Win32_ComputerSystem).PartOfDomain
    DomainName      = (Get-CimInstance Win32_ComputerSystem).Domain
}
$info | ConvertTo-Json</textarea>
                    <button type="button" class="btn btn-sm btn-secondary position-absolute top-0 end-0 m-2" id="copyScriptBtn">
                        Copy
                    </button>
                </div>
                <p class="text-muted mb-2">
                    <strong>Step 2</strong> — Paste the JSON output here:
                </p>
                <textarea id="psResults" class="form-control font-monospace" rows="6"
                          placeholder='{"Hostname":"...","IpAddress":"...","OperatingSystem":"...","RamGb":16,...}'
                          style="font-size:0.82rem;"></textarea>
                <div id="psParseError" class="text-danger mt-1 d-none">Invalid JSON — paste the full output from the script.</div>
                <div id="psApplySuccess" class="text-success mt-1 d-none">Fields populated! Review and save the form.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="psApplyBtn">Apply to Form</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var categorySelect = document.getElementById('Category');
            function showSection(sel) {
                var text = sel.options[sel.selectedIndex].text.replace(/\s+/g, '');
                document.querySelectorAll('.asset-type-section').forEach(function (s) {
                    s.classList.add('d-none');
                });
                var el = document.getElementById('section-' + text);
                if (el) el.classList.remove('d-none');
            }
            if (categorySelect) {
                categorySelect.addEventListener('change', function (e) { showSection(e.target); });
                showSection(categorySelect);
            }

            // Domain Joined → show/hide Domain Name field
            var djCb = document.getElementById('DomainJoined');
            var dnRow = document.getElementById('domainNameRow');
            function toggleDomain() { if (dnRow) dnRow.classList.toggle('d-none', !djCb.checked); }
            if (djCb) { djCb.addEventListener('change', toggleDomain); toggleDomain(); }

            // Copy script
            document.getElementById('copyScriptBtn').addEventListener('click', function () {
                navigator.clipboard.writeText(document.getElementById('psScript').value).then(function () {
                    var btn = document.getElementById('copyScriptBtn');
                    btn.textContent = 'Copied!';
                    btn.classList.replace('btn-secondary', 'btn-success');
                    setTimeout(function () { btn.textContent = 'Copy'; btn.classList.replace('btn-success', 'btn-secondary'); }, 2000);
                });
            });

            // Apply results to form fields
            document.getElementById('psApplyBtn').addEventListener('click', function () {
                var raw = document.getElementById('psResults').value.trim();
                var errDiv = document.getElementById('psParseError');
                var okDiv  = document.getElementById('psApplySuccess');
                errDiv.classList.add('d-none');
                okDiv.classList.add('d-none');
                try {
                    var data = JSON.parse(raw);
                    if (data.Hostname)        { var n = document.getElementById('Name'); if (n && !n.value) n.value = data.Hostname; }
                    if (data.IpAddress)       { var f = document.getElementById('IpAddress');       if (f) f.value = data.IpAddress; }
                    if (data.OperatingSystem) { var f = document.getElementById('OperatingSystem'); if (f) f.value = data.OperatingSystem; }
                    if (data.RamGb)           { var f = document.getElementById('RamGb');           if (f) f.value = data.RamGb; }
                    if (data.CpuModel)        { var f = document.getElementById('CpuModel');        if (f) f.value = data.CpuModel; }
                    if (data.SerialNumber)    { var f = document.getElementById('SerialNumber');    if (f) f.value = data.SerialNumber; }
                    var dj = document.getElementById('DomainJoined');
                    if (dj && data.DomainJoined !== undefined) { dj.checked = !!data.DomainJoined; toggleDomain(); }
                    if (data.DomainName)     { var f = document.getElementById('DomainName');     if (f) f.value = data.DomainName; }
                    okDiv.classList.remove('d-none');
                    setTimeout(function () {
                        var modal = bootstrap.Modal.getInstance(document.getElementById('psQueryModal'));
                        if (modal) modal.hide();
                    }, 1200);
                } catch (e) {
                    errDiv.classList.remove('d-none');
                }
            });
        })();
    </script>
}
