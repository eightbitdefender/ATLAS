@model ATLAS.Models.Asset
@{
    ViewData["Title"] = Model.Name;
    var grouped = Model.AssetVulnerabilities
        .GroupBy(av => av.Status)
        .ToDictionary(g => g.Key, g => g.Count());
}

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>@Model.Name</h2>
        <small class="text-muted">@Model.Category — @Model.SubTypeLabel</small>
    </div>
    <div>
        @if (Model is ATLAS.Models.Computer)
        {
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#psQueryModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-terminal me-1" viewBox="0 0 16 16">
                    <path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9M3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708z"/>
                    <path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/>
                </svg>
                Query PowerShell
            </button>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-controller="AssetVulnerabilities" asp-action="Create" asp-route-assetId="@Model.Id" class="btn btn-danger">+ Assign Vulnerability</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Common Info Card -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><strong>Asset Info</strong></div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-3">@Model.Description</p>
                    <hr class="mt-0 mb-3" />
                }
                <dl class="row mb-0">
                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category — @Model.SubTypeLabel</dd>
                    <dt class="col-sm-4">Owner</dt>
                    <dd class="col-sm-8">@(Model.Owner ?? "—")</dd>
                    <dt class="col-sm-4">Business Stakeholder</dt>
                    <dd class="col-sm-8">@(Model.BusinessStakeholder ?? "—")</dd>
                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">@(Model.Department ?? "—")</dd>
                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@(Model.Location ?? "—")</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-@(Model.Status == ATLAS.Models.AssetStatus.Active ? "success" : "secondary")">@Model.Status</span>
                    </dd>
                    <dt class="col-sm-4">Added</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>
                    @if (Model.LastUpdated.HasValue)
                    {
                        <dt class="col-sm-4">Updated</dt>
                        <dd class="col-sm-8">@Model.LastUpdated.Value.ToString("yyyy-MM-dd")</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <dt class="col-sm-4">Notes</dt>
                        <dd class="col-sm-8">@Model.Notes</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <!-- Type-specific Details Card -->
    <div class="col-md-6">
        <div class="card h-100">
            @if (Model is ATLAS.Models.Computer comp)
            {
                <div class="card-header"><strong>Computer Details</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Type</dt>       <dd class="col-sm-7">@comp.ComputerType</dd>
                        <dt class="col-sm-5">IP Address</dt> <dd class="col-sm-7">@(comp.IpAddress ?? "—")</dd>
                        <dt class="col-sm-5">OS</dt>         <dd class="col-sm-7">@(comp.OperatingSystem ?? "—")</dd>
                        <dt class="col-sm-5">CPU</dt>        <dd class="col-sm-7">@(comp.CpuModel ?? "—")</dd>
                        <dt class="col-sm-5">RAM</dt>        <dd class="col-sm-7">@(comp.RamGb.HasValue ? comp.RamGb + " GB" : "—")</dd>
                        <dt class="col-sm-5">Serial #</dt>   <dd class="col-sm-7">@(comp.SerialNumber ?? "—")</dd>
                        <dt class="col-sm-5">Domain Joined</dt>
                        <dd class="col-sm-7">
                            @if (comp.DomainJoined) { <span class="badge bg-success">Yes</span> } else { <span class="text-muted">No</span> }
                        </dd>
                    </dl>
                </div>
            }
            else if (Model is ATLAS.Models.NetworkDevice nd)
            {
                <div class="card-header"><strong>Network Device Details</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Device Type</dt><dd class="col-sm-7">@nd.NetworkDeviceType</dd>
                        <dt class="col-sm-5">IP Address</dt> <dd class="col-sm-7">@(nd.IpAddress ?? "—")</dd>
                        <dt class="col-sm-5">MAC Address</dt><dd class="col-sm-7">@(nd.MacAddress ?? "—")</dd>
                        <dt class="col-sm-5">Firmware</dt>   <dd class="col-sm-7">@(nd.Firmware ?? "—")</dd>
                        <dt class="col-sm-5">Ports</dt>      <dd class="col-sm-7">@(nd.PortCount.HasValue ? nd.PortCount.ToString() : "—")</dd>
                        <dt class="col-sm-5">Managed</dt>
                        <dd class="col-sm-7">
                            @if (nd.Managed) { <span class="badge bg-success">Yes</span> } else { <span class="text-muted">No</span> }
                        </dd>
                    </dl>
                </div>
            }
            else if (Model is ATLAS.Models.Printer pr)
            {
                <div class="card-header"><strong>Printer Details</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Printer Type</dt>  <dd class="col-sm-7">@pr.PrinterType</dd>
                        <dt class="col-sm-5">Model</dt>         <dd class="col-sm-7">@(pr.Model ?? "—")</dd>
                        <dt class="col-sm-5">IP Address</dt>    <dd class="col-sm-7">@(pr.IpAddress ?? "—")</dd>
                        <dt class="col-sm-5">Color</dt>
                        <dd class="col-sm-7">@if (pr.ColorCapable) { <span class="badge bg-success">Yes</span> } else { <span class="text-muted">No</span> }</dd>
                        <dt class="col-sm-5">Networked</dt>
                        <dd class="col-sm-7">@if (pr.NetworkConnected) { <span class="badge bg-success">Yes</span> } else { <span class="text-muted">No</span> }</dd>
                    </dl>
                </div>
            }
            else if (Model is ATLAS.Models.SoftwareApplication sa)
            {
                <div class="card-header"><strong>Application Details</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">App Type</dt>    <dd class="col-sm-7">@sa.ApplicationType</dd>
                        <dt class="col-sm-5">Vendor</dt>      <dd class="col-sm-7">@(sa.Vendor ?? "—")</dd>
                        <dt class="col-sm-5">Version</dt>     <dd class="col-sm-7">@(sa.Version ?? "—")</dd>
                        <dt class="col-sm-5">License</dt>     <dd class="col-sm-7">@(sa.LicenseType ?? "—")</dd>
                        <dt class="col-sm-5">URL</dt>
                        <dd class="col-sm-7">
                            @if (!string.IsNullOrEmpty(sa.Url))
                            {
                                <a href="@sa.Url" target="_blank" rel="noopener">@sa.Url</a>
                            }
                            else { <span class="text-muted">—</span> }
                        </dd>
                    </dl>
                </div>
            }
            else if (Model is ATLAS.Models.MobileDevice md)
            {
                <div class="card-header"><strong>Mobile Device Details</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Device Type</dt><dd class="col-sm-7">@md.MobileDeviceType</dd>
                        <dt class="col-sm-5">OS</dt>         <dd class="col-sm-7">@(md.OperatingSystem ?? "—")</dd>
                        <dt class="col-sm-5">IMEI</dt>       <dd class="col-sm-7">@(md.Imei ?? "—")</dd>
                        <dt class="col-sm-5">Phone #</dt>    <dd class="col-sm-7">@(md.PhoneNumber ?? "—")</dd>
                        <dt class="col-sm-5">Carrier</dt>    <dd class="col-sm-7">@(md.Carrier ?? "—")</dd>
                    </dl>
                </div>
            }
            else if (Model is ATLAS.Models.CloudResource cr)
            {
                <div class="card-header"><strong>Cloud Resource Details</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Provider</dt>     <dd class="col-sm-7">@cr.CloudProvider</dd>
                        <dt class="col-sm-5">Resource Type</dt><dd class="col-sm-7">@(cr.ResourceType ?? "—")</dd>
                        <dt class="col-sm-5">Region</dt>       <dd class="col-sm-7">@(cr.Region ?? "—")</dd>
                        <dt class="col-sm-5">Account ID</dt>   <dd class="col-sm-7">@(cr.AccountId ?? "—")</dd>
                        <dt class="col-sm-5">Resource ID</dt>  <dd class="col-sm-7"><small class="text-break">@(cr.ResourceId ?? "—")</small></dd>
                    </dl>
                </div>
            }
        </div>
    </div>

    <!-- Vulnerability Summary Card -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>Vulnerability Summary</strong></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li>Open: <strong>@(grouped.GetValueOrDefault(ATLAS.Models.RemediationStatus.Open, 0))</strong></li>
                    <li>In Progress: <strong>@(grouped.GetValueOrDefault(ATLAS.Models.RemediationStatus.InProgress, 0))</strong></li>
                    <li>Remediated: <strong>@(grouped.GetValueOrDefault(ATLAS.Models.RemediationStatus.Remediated, 0))</strong></li>
                    <li>Total: <strong>@Model.AssetVulnerabilities.Count</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<h4>Assigned Vulnerabilities</h4>
<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr><th>CVE</th><th>Title</th><th>Severity</th><th>CVSS</th><th>Status</th><th>Detected</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var av in Model.AssetVulnerabilities.OrderBy(av => av.Vulnerability.Severity))
        {
            <tr>
                <td><small>@(av.Vulnerability.CveId ?? "—")</small></td>
                <td>@av.Vulnerability.Title</td>
                <td><span class="severity-@av.Vulnerability.Severity.ToString().ToLower()">@av.Vulnerability.Severity</span></td>
                <td>@(av.Vulnerability.CvssScore?.ToString("F1") ?? "—")</td>
                <td>
                    <span class="badge bg-@(av.Status == ATLAS.Models.RemediationStatus.Open ? "danger" :
                                            av.Status == ATLAS.Models.RemediationStatus.InProgress ? "warning" :
                                            av.Status == ATLAS.Models.RemediationStatus.Remediated ? "success" : "secondary")">
                        @av.Status
                    </span>
                </td>
                <td><small>@av.DetectedAt.ToString("yyyy-MM-dd")</small></td>
                <td>
                    <a asp-controller="AssetVulnerabilities" asp-action="Edit" asp-route-id="@av.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-controller="AssetVulnerabilities" asp-action="Delete" asp-route-id="@av.Id" method="post" style="display:inline"
                          onsubmit="return confirm('Remove this finding?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.AssetVulnerabilities.Any())
        {
            <tr><td colspan="7" class="text-center text-muted py-3">No vulnerabilities assigned.</td></tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-link">← Back to Assets</a>

@if (Model is ATLAS.Models.Computer)
{
    <!-- PowerShell Query Modal -->
    <div class="modal fade" id="psQueryModal" tabindex="-1" aria-labelledby="psQueryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="psQueryModalLabel">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-terminal me-2" viewBox="0 0 16 16">
                            <path d="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9M3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708z"/>
                            <path d="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/>
                        </svg>
                        Query Computer with PowerShell
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-2">
                        <strong>Step 1</strong> — Copy this script and run it in PowerShell on <strong>@Model.Name</strong>:
                    </p>
                    <div class="position-relative mb-3">
                        <textarea id="psScript" class="form-control font-monospace" rows="11" readonly style="font-size:0.82rem; background:#1e1e1e; color:#d4d4d4; resize:none;">$info = [ordered]&#64;{
    Hostname        = $env:COMPUTERNAME
    IpAddress       = (Get-NetIPAddress -AddressFamily IPv4 |
                           Where-Object { $_.IPAddress -notlike '127.*' -and
                                          $_.IPAddress -notlike '169.254.*' } |
                           Sort-Object PrefixLength -Descending |
                           Select-Object -First 1).IPAddress
    OperatingSystem = (Get-CimInstance Win32_OperatingSystem).Caption
    RamGb           = [int][Math]::Ceiling(
                           (Get-CimInstance Win32_PhysicalMemoryArray |
                            Measure-Object -Property MaxCapacity -Sum).Sum / 1MB)
    CpuModel        = ((Get-CimInstance Win32_Processor)[0].Name).Trim()
    SerialNumber    = ((Get-CimInstance Win32_BIOS).SerialNumber).Trim()
    DomainJoined    = (Get-CimInstance Win32_ComputerSystem).PartOfDomain
}
$info | ConvertTo-Json</textarea>
                        <button type="button" class="btn btn-sm btn-secondary position-absolute top-0 end-0 m-2" id="copyScriptBtn">
                            Copy
                        </button>
                    </div>

                    <p class="text-muted mb-2">
                        <strong>Step 2</strong> — Paste the JSON output here:
                    </p>
                    <textarea id="psResults" class="form-control font-monospace" rows="6"
                              placeholder='{"Hostname":"...","IpAddress":"...","OperatingSystem":"...","RamGb":16,...}'
                              style="font-size:0.82rem;"></textarea>
                    <div id="psParseError" class="text-danger mt-1 d-none">Invalid JSON — paste the full output from the script.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="ApplyPsQuery" asp-route-id="@Model.Id" method="post" id="psApplyForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="resultsJson" id="psResultsHidden" />
                        <button type="button" class="btn btn-primary" id="psApplyBtn">Apply Results</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            // Copy script button
            document.getElementById('copyScriptBtn').addEventListener('click', function () {
                var ta = document.getElementById('psScript');
                navigator.clipboard.writeText(ta.value).then(function () {
                    var btn = document.getElementById('copyScriptBtn');
                    btn.textContent = 'Copied!';
                    btn.classList.replace('btn-secondary', 'btn-success');
                    setTimeout(function () {
                        btn.textContent = 'Copy';
                        btn.classList.replace('btn-success', 'btn-secondary');
                    }, 2000);
                });
            });

            // Apply results — validate JSON then submit
            document.getElementById('psApplyBtn').addEventListener('click', function () {
                var raw = document.getElementById('psResults').value.trim();
                var errDiv = document.getElementById('psParseError');
                try {
                    JSON.parse(raw); // validate
                    errDiv.classList.add('d-none');
                    document.getElementById('psResultsHidden').value = raw;
                    document.getElementById('psApplyForm').submit();
                } catch (e) {
                    errDiv.classList.remove('d-none');
                }
            });
        })();
    </script>
}
