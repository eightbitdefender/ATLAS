@model IEnumerable<CMDB.Models.Asset>
@{
    ViewData["Title"] = "Assets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Assets</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Asset</a>
</div>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Type / Subtype</th>
            <th>Identifier</th>
            <th>Owner</th>
            <th>Status</th>
            <th>Open Findings</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            var openCount = a.AssetVulnerabilities.Count(av => av.Status == CMDB.Models.RemediationStatus.Open);
            <tr>
                <td><a asp-action="Details" asp-route-id="@a.Id">@a.Name</a></td>
                <td>@a.Category</td>
                <td>@a.SubTypeLabel</td>
                <td><small class="text-muted">@(a.Identifier ?? "—")</small></td>
                <td>@(a.Owner ?? "—")</td>
                <td>
                    <span class="badge bg-@(a.Status == CMDB.Models.AssetStatus.Active ? "success" : "secondary")">
                        @a.Status
                    </span>
                </td>
                <td>
                    @if (openCount > 0)
                    {
                        <span class="badge bg-danger">@openCount open</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="8" class="text-center text-muted py-4">No assets yet. <a asp-action="Create">Add one.</a></td></tr>
        }
    </tbody>
</table>
